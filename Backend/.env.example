# ─────────────────────────────────────────────
#  IronForge Gym — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local:   mongodb://localhost:27017/ironforge
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/ironforge
MONGODB_URI=mongodb://localhost:27017/ironforge

# JWT Secret (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email (for registration confirmation emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gym_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=IronForge Gym <noreply@ironforge.com>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin credentials (first admin account)
ADMIN_EMAIL=admin@ironforge.com
ADMIN_PASSWORD=Admin@123456
